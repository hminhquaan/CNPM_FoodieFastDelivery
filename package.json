{
  "name": "foodfastdelivery-backend-runner",
  "version": "1.0.0",
  "private": true,
  "description": "NPM wrapper scripts to run the Spring Boot backend easily",
  "scripts": {
    "dev": "cross-env SPRING_PROFILES_ACTIVE=dev mvn -q -f ./pom.xml spring-boot:run",
    "build": "mvn -DskipTests package",
    "start": "java -jar target/backend-0.0.1-SNAPSHOT.jar",
    "clean": "mvn clean"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  }
}
